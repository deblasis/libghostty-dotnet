--file
libghostty/include/ghostty.h
--namespace
Ghostty.Interop
--libraryPath
ghostty
--methodClassName
NativeMethods
--output
src/Ghostty.Interop/Generated
--language
c
--config
generate-macro-bindings
latest-codegen
generate-helper-types
--with-access-specifier
*=public
--exclude
GHOSTTY_H
GHOSTTY_SUCCESS
--remap
ghostty_app_t=nint
ghostty_config_t=nint
ghostty_surface_t=nint
ghostty_inspector_t=nint
--additional
-DGHOSTTY_EXPORT=
-D_WIN64
-D_MSC_VER=1940
-DSSIZE_T=long long
